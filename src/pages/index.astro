---
import BaseLayout from "../layouts/BaseLayout.astro";
import CrystallineGlyph from "../components/CrystallineGlyph.astro";
import { SITE, caseStudies, nextMoves, offers } from "../data/site";

// Growth-loop diagram geometry (five connected stages, clockwise).
const loopStages = ["Positioning", "Content", "Experience", "Conversion", "Measurement"];
const LCX = 330, LCY = 225, LR = 148, LBL = LR + 40, GAP = (18 * Math.PI) / 180;
const ang = (i: number) => ((-90 + i * 72) * Math.PI) / 180;
const polar = (a: number, r: number): [number, number] => [LCX + r * Math.cos(a), LCY + r * Math.sin(a)];
const rr = (n: number) => Math.round(n * 10) / 10;

const loopNodes = loopStages.map((label, i) => {
  const a = ang(i);
  const [x, y] = polar(a, LR);
  const [lx, ly] = polar(a, LBL);
  const ca = Math.cos(a), sa = Math.sin(a);
  const anchor = ca > 0.3 ? "start" : ca < -0.3 ? "end" : "middle";
  const dy = sa > 0.3 ? 22 : sa < -0.3 ? -12 : 8;
  return { label, x: rr(x), y: rr(y), lx: rr(lx), ly: rr(ly + dy), anchor, accent: i === 3 };
});

const loopArcs = loopStages.map((_, i) => {
  const a0 = ang(i) + GAP, a1 = ang((i + 1) % 5) - GAP;
  const [sx, sy] = polar(a0, LR), [ex, ey] = polar(a1, LR);
  const dx = -Math.sin(a1), dy = Math.cos(a1), px = -dy, py = dx;
  const tip = [ex + dx * 8, ey + dy * 8];
  const b1 = [ex - dx * 2 + px * 4.5, ey - dy * 2 + py * 4.5];
  const b2 = [ex - dx * 2 - px * 4.5, ey - dy * 2 - py * 4.5];
  return {
    d: `M ${rr(sx)} ${rr(sy)} A ${LR} ${LR} 0 0 1 ${rr(ex)} ${rr(ey)}`,
    head: `M ${rr(tip[0])} ${rr(tip[1])} L ${rr(b1[0])} ${rr(b1[1])} L ${rr(b2[0])} ${rr(b2[1])} Z`
  };
});

const offerGlyphs = ["strategy", "content", "conversion", "analytics"] as const;
const nextGlyphs = ["strategy", "content", "conversion", "analytics"] as const;
---

<BaseLayout>
  <section class="hero" data-hero-field>
    <div class="hero-copy">
      <p class="kicker">NiceSalt · Digital studio</p>
      <h1>We build the part that makes the rest work.</h1>
      <p class="lede">
        Expert-led brands grow when positioning, content, UX, conversion, and
        measurement pull in the same direction. We design, build, and tune the
        whole system.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="#next">Find the next move</a>
        <a class="button ghost" href="/case-studies/">See selected work</a>
      </div>
      <p class="hero-meta">Independent studio · Williamsburg, New York</p>
    </div>
    <canvas class="salt-field" data-salt aria-hidden="true"></canvas>
  </section>

  <section class="offers-band" aria-label="What we work across">
    {offers.map((offer, index) => (
      <a href="#contact" data-reveal>
        <CrystallineGlyph kind={offerGlyphs[index]} />
        <strong>{offer.title}</strong>
        <span>{offer.text}</span>
      </a>
    ))}
  </section>

  <section class="system-section" id="system" aria-labelledby="system-title" data-reveal>
    <div class="system-copy">
      <p class="kicker">How it connects</p>
      <h2 id="system-title">The advantage is in the loop.</h2>
      <p>
        Most teams run content, UX, and analytics as separate projects. We treat
        them as one loop, where each part feeds the next.
      </p>
    </div>
    <figure class="loop-figure">
      <CrystallineGlyph kind="divider" class="loop-divider" />
      <svg viewBox="0 0 660 480" role="img" aria-label="A growth loop: positioning, content, experience, conversion, and measurement, each feeding the next.">
        {loopArcs.map((a) => <path class="loop-arc" d={a.d} />)}
        {loopArcs.map((a) => <path class="loop-head" d={a.head} />)}
        {loopNodes.map((n) => <circle class={n.accent ? "loop-node accent" : "loop-node"} cx={n.x} cy={n.y} r="8" />)}
        {loopNodes.map((n) => (
          <text class="loop-label" x={n.lx} y={n.ly} text-anchor={n.anchor}>{n.label}</text>
        ))}
      </svg>
    </figure>
  </section>

  <section class="next-section" id="next" aria-labelledby="next-title">
    <div class="section-heading">
      <p class="kicker">Start here</p>
      <h2 id="next-title">Where are you stuck?</h2>
      <p>Pick what's closest — it just gives us a useful first note.</p>
    </div>
    <div class="next-grid" data-next-move>
      {nextMoves.map((item, index) => (
        <button
          class="next-choice"
          type="button"
          data-choice={item.id}
          data-project-type={item.projectType}
          data-message={`I'm interested in ${item.projectType}. ${item.text}`}
          aria-pressed={index === 0 ? "true" : "false"}
        >
          <span>{String(index + 1).padStart(2, "0")}</span>
          <CrystallineGlyph kind={nextGlyphs[index]} />
          <strong>{item.title}</strong>
          <em>{item.text}</em>
        </button>
      ))}
    </div>
  </section>

  <section class="work-section" aria-labelledby="work-title">
    <div class="section-heading compact">
      <p class="kicker">Selected work</p>
      <h2 id="work-title">Two recent examples.</h2>
    </div>
    <div class="work-list">
      {caseStudies.map((study) => (
        <article class="work-row" data-reveal>
          <a class="work-image" href={`/case-studies/${study.slug}/`}>
            <img src={study.image} alt={study.alt} loading="lazy" decoding="async" />
          </a>
          <div>
            <p class="kicker">{study.label}</p>
            <h3><a href={`/case-studies/${study.slug}/`}>{study.name}</a></h3>
            <p>{study.summary}</p>
            <a class="text-link" href={`/case-studies/${study.slug}/`}>Read the case study</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="contact-section" id="contact" aria-labelledby="contact-title">
    <div class="section-heading">
      <p class="kicker">Contact</p>
      <h2 id="contact-title">Tell us what you're working on.</h2>
      <p>
        You work directly with the person doing the work. We focus on
        expert-led teams in health, science, and media. A short note is enough
        to start.
      </p>
    </div>
    <form class="contact-form" action={SITE.formAction} method="POST">
      <input type="hidden" name="_subject" value="NiceSalt project inquiry" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_honey" value="" />
      <input type="hidden" name="_next" value={`${SITE.url}/thanks/`} />
      <label>
        <span>Name</span>
        <input name="name" autocomplete="name" required />
      </label>
      <label>
        <span>Email</span>
        <input type="email" name="email" autocomplete="email" required />
      </label>
      <label>
        <span>Company or project</span>
        <input name="company" autocomplete="organization" />
      </label>
      <label>
        <span>What needs to get unstuck?</span>
        <select name="project_type" data-project-type required>
          <option value="Positioning & UX">Positioning &amp; UX</option>
          <option value="Content & distribution">Content &amp; distribution</option>
          <option value="Conversion">Conversion</option>
          <option value="Analytics & growth">Analytics &amp; growth</option>
        </select>
      </label>
      <label class="wide">
        <span>Budget or timeline, if useful</span>
        <input name="budget_timeline" />
      </label>
      <label class="wide">
        <span>What is going on?</span>
        <textarea name="message" rows="6" data-message required></textarea>
      </label>
      <button class="button primary" type="submit">Send inquiry</button>
    </form>
  </section>
</BaseLayout>
