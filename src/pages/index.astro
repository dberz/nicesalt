---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceIllustration from "../components/ServiceIllustration.astro";
import { SITE, caseStudies, faqs, nextMoves, offers } from "../data/site";

const offerGlyphs = ["strategy", "content", "conversion", "analytics"] as const;
---

<BaseLayout>
  <section class="hero" data-hero-field>
    <div class="hero-copy">
      <p class="kicker">For expert-led brands</p>
      <h1>A small digital studio with great taste.</h1>
      <p class="lede">
        Most sites built for experts undersell them — thin positioning,
        content that doesn't compound, a path to contact that quietly leaks.
        We fix the whole chain, not just the page.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="#next">Find the next move</a>
        <a class="button ghost" href="/case-studies/">See selected work</a>
      </div>
    </div>
    <canvas class="hero-salt-field" data-hero-salt aria-hidden="true"></canvas>
  </section>

  <section class="offers-section" aria-labelledby="offers-title">
    <div class="section-heading compact">
      <p class="kicker">What we do</p>
      <h2 id="offers-title">Four disciplines. One system.</h2>
    </div>
    <div class="offers-band" aria-label="What we work across">
      {offers.map((offer, index) => (
        <a href="#contact" data-reveal>
          <ServiceIllustration kind={offerGlyphs[index]} />
          <strong>{offer.title}</strong>
          <span>{offer.text}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="system-section" id="system" aria-labelledby="system-title" data-reveal>
    <div class="system-copy">
      <p class="kicker">The approach</p>
      <h2 id="system-title">We run the whole loop.</h2>
      <p>
        Most teams run content, UX, and analytics as separate projects — a
        blog contractor here, a design freelancer there, an analytics
        dashboard nobody opens. We treat it as one loop: each stage feeds the
        next, and nothing ships in isolation.
      </p>
    </div>
    <figure class="loop-figure">
      <svg class="loop-diagram" viewBox="0 0 660 480" role="img" aria-label="A connected growth loop: positioning feeds content, content feeds experience, experience feeds conversion, conversion feeds measurement, and measurement informs positioning.">
        <defs>
          <marker id="loop-arrow" viewBox="0 0 12 12" refX="9" refY="6" markerWidth="8" markerHeight="8" orient="auto">
            <path d="M2 2 L10 6 L2 10 Z" />
          </marker>
        </defs>
        <circle class="loop-orbit" cx="330" cy="238" r="126" />
        <path class="loop-flow" d="M330 112 A126 126 0 1 1 329 112" />
        <g class="loop-runner">
          <path class="loop-runner-grain" d="M330 105 L335 112 L330 119 L325 112 Z" />
        </g>
        <g class="loop-hub">
          <path class="hub-plane pale" d="M330 184 L291 238 L330 238 Z" />
          <path class="hub-plane teal" d="M330 184 L369 238 L330 238 Z" />
          <path class="hub-plane blue" d="M330 292 L369 238 L330 238 Z" />
          <path class="hub-plane stone" d="M330 292 L291 238 L330 238 Z" />
          <path class="hub-seam" d="M330 184V292M291 238H369" />
          <path class="hub-outline" d="M330 184 L369 238 L330 292 L291 238 Z" />
        </g>
        <circle class="loop-hub-node teal" cx="438" cy="238" r="5" />
        <circle class="loop-hub-node blue" cx="276" cy="348" r="5" />
        <circle class="loop-hub-node stone" cx="226" cy="220" r="5" />
        <g class="loop-stage stage-positioning">
          <circle cx="330" cy="80" r="7" />
          <text x="330" y="42" text-anchor="middle">Positioning</text>
        </g>
        <g class="loop-stage stage-content">
          <circle cx="482" cy="190" r="7" />
          <text x="512" y="196">Content</text>
        </g>
        <g class="loop-stage stage-experience">
          <circle cx="424" cy="368" r="7" />
          <text x="436" y="416">Experience</text>
        </g>
        <g class="loop-stage stage-conversion">
          <circle cx="236" cy="368" r="7" />
          <text x="226" y="416" text-anchor="end">Conversion</text>
        </g>
        <g class="loop-stage stage-measurement">
          <circle cx="178" cy="190" r="7" />
          <text x="148" y="196" text-anchor="end">Measurement</text>
        </g>
        <path class="loop-connector" d="M330 112 C380 118 448 142 482 190" marker-end="url(#loop-arrow)" />
        <path class="loop-connector" d="M482 190 C486 250 466 326 424 368" marker-end="url(#loop-arrow)" />
        <path class="loop-connector" d="M424 368 C372 398 284 398 236 368" marker-end="url(#loop-arrow)" />
        <path class="loop-connector" d="M236 368 C194 326 174 250 178 190" marker-end="url(#loop-arrow)" />
        <path class="loop-connector" d="M178 190 C212 142 280 118 330 112" marker-end="url(#loop-arrow)" />
      </svg>
    </figure>
  </section>

  <section class="next-section" id="next" aria-labelledby="next-title">
    <div class="section-heading">
      <p class="kicker">Start here</p>
      <h2 id="next-title">Where are you stuck?</h2>
      <p>
        Most projects start as one of these four problems. Pick the closest —
        it gives your first note a useful starting point.
      </p>
    </div>
    <div class="next-grid" data-next-move>
      {nextMoves.map((item, index) => (
        <button
          class="next-choice"
          type="button"
          data-choice={item.id}
          data-project-type={item.projectType}
          data-message={`I'm interested in ${item.projectType}. ${item.text}`}
          aria-pressed={index === 0 ? "true" : "false"}
        >
          <span>{String(index + 1).padStart(2, "0")}</span>
          <strong>{item.title}</strong>
          <em>{item.text}</em>
        </button>
      ))}
    </div>
    <p class="next-followup" data-next-followup>
      <span>Sounds right?</span>
      <a class="text-link" href="#contact">Tell us about it</a>
    </p>
  </section>

  <section class="work-section" aria-label="Selected work">
    <div class="section-heading compact">
      <h2>Selected work</h2>
    </div>
    <div class="work-list">
      {caseStudies.map((study) => (
        <article class="work-row" data-reveal>
          <a class="work-image" href={`/case-studies/${study.slug}/`}>
            <img src={study.image} alt={study.alt} loading="lazy" decoding="async" />
          </a>
          <div>
            <p class="kicker">{study.label}</p>
            <h3><a href={`/case-studies/${study.slug}/`}>{study.name}</a></h3>
            <p>{study.summary}</p>
            <a class="text-link" href={`/case-studies/${study.slug}/`}>Read the case study</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="notes-section" aria-labelledby="faq-title" data-reveal>
    <div class="section-heading compact">
      <p class="kicker">Good questions</p>
      <h2 id="faq-title">Before you write.</h2>
    </div>
    <div class="notes-list">
      {faqs.map((faq) => (
        <div class="note-row">
          <h3>{faq.question}</h3>
          <p>{faq.answer}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="contact-section" id="contact" aria-labelledby="contact-title">
    <div class="section-heading">
      <p class="kicker">Contact</p>
      <h2 id="contact-title">Tell us what you're working on.</h2>
      <p>
        NiceSalt is the consulting practice of
        <a class="text-link inline" href={SITE.principal.url} rel="me">{SITE.principal.name}</a>.
        You work directly with the person doing the work — no account
        managers, no hand-offs. Most of what we've shipped is in health,
        science, and media. A short note is enough to start.
      </p>
    </div>
    <form class="contact-form" action={SITE.formAction} method="POST">
      <input type="hidden" name="_subject" value="NiceSalt project inquiry" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_honey" value="" />
      <input type="hidden" name="_next" value={`${SITE.url}/thanks/`} />
      <label>
        <span>Name</span>
        <input name="name" autocomplete="name" required />
      </label>
      <label>
        <span>Email</span>
        <input type="email" name="email" autocomplete="email" required />
      </label>
      <label>
        <span>Company or project</span>
        <input name="company" autocomplete="organization" />
      </label>
      <label>
        <span>What needs to get unstuck?</span>
        <select name="project_type" data-project-type required>
          <option value="Positioning & UX">Positioning &amp; UX</option>
          <option value="Content & distribution">Content &amp; distribution</option>
          <option value="Conversion">Conversion</option>
          <option value="Analytics & growth">Analytics &amp; growth</option>
        </select>
      </label>
      <label class="wide">
        <span>Budget or timeline, if useful</span>
        <input name="budget_timeline" />
      </label>
      <label class="wide">
        <span>What is going on?</span>
        <textarea name="message" rows="6" data-message required></textarea>
      </label>
      <button class="button primary" type="submit">Send inquiry</button>
    </form>
  </section>
</BaseLayout>
