---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { caseStudies } from "../../data/site";
---

<BaseLayout
  title="Selected work"
  description="Two NiceSalt projects, start to finish: an editorial platform and an early-stage health product."
  path="/case-studies/"
>
  <section class="page-hero">
    <p class="kicker">Selected work</p>
    <h1>Two projects worth showing.</h1>
    <p>
      Different problems, same approach: figure out what's actually broken,
      then build the smallest thing that fixes it.
    </p>
  </section>
  <section class="work-section solo">
    <div class="work-list" data-analytics-component="work_index" data-analytics-event="recirculation">
      {caseStudies.map((study) => (
        <article class="work-row" data-reveal>
          <a class="work-image" href={`/case-studies/${study.slug}/`}>
            <img src={study.image} alt={study.alt} loading="lazy" decoding="async" />
          </a>
          <div>
            <p class="kicker">{study.label}</p>
            <h2><a href={`/case-studies/${study.slug}/`}>{study.name}</a></h2>
            <p>{study.summary}</p>
            <a class="text-link" href={`/case-studies/${study.slug}/`}>Read the case study</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
