---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { caseStudies } from "../../data/site";
---

<BaseLayout
  title="Selected work"
  description="Selected NiceSalt work across websites, prototypes, content workflows, and useful AI features."
  path="/case-studies/"
>
  <section class="page-hero">
    <p class="kicker">Selected work</p>
    <h1>Proof, not promises.</h1>
    <p>
      Two examples across editorial web, product prototyping, content systems,
      and AI-assisted product experience.
    </p>
  </section>
  <section class="work-section solo">
    <div class="work-list">
      {caseStudies.map((study) => (
        <article class="work-row" data-reveal>
          <a class="work-image" href={`/case-studies/${study.slug}/`}>
            <img src={study.image} alt={study.alt} loading="lazy" decoding="async" />
          </a>
          <div>
            <p class="kicker">{study.label}</p>
            <h2><a href={`/case-studies/${study.slug}/`}>{study.name}</a></h2>
            <p>{study.summary}</p>
            <a class="text-link" href={`/case-studies/${study.slug}/`}>Read the case study</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
