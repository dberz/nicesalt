---
import "../styles/global.css";
import SaltMark from "../components/SaltMark.astro";
import { SITE } from "../data/site";
import { baseJsonLd, canonical, metaTitle } from "../utils/seo";

type Props = {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  jsonLd?: unknown[];
};

const {
  title,
  description = SITE.description,
  path = "/",
  image = "/images/og/nicesalt-og.png",
  jsonLd = []
} = Astro.props;

const pageUrl = canonical(path);
const pageTitle = metaTitle(title);
const imageUrl = canonical(image);
const structuredData = [...baseJsonLd(), ...jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <link rel="preload" href="/fonts/Satoshi-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Satoshi-Black.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#f6f0e7" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    {SITE.ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.ga4Id}`}></script>
        <script
          set:html={`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${SITE.ga4Id}');`}
        />
      </>
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" data-header>
      <a class="wordmark" href="/" aria-label="NiceSalt home"><SaltMark size={20} />NiceSalt</a>
      <button
        class="nav-toggle"
        type="button"
        data-nav-toggle
        aria-expanded="false"
        aria-controls="primary-nav"
        aria-label="Toggle menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav
        aria-label="Primary navigation"
        id="primary-nav"
        data-nav
        data-analytics-component="header_nav"
        data-analytics-event="navigation"
      >
        <a href="/#system">Approach</a>
        <a href="/case-studies/">Work</a>
        <a href="/notes/">Notes</a>
        <a
          class="button primary small nav-cta"
          href="/#contact"
          data-analytics-component="header_nav_cta"
          data-analytics-event="cta"
        >Start a project</a>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer" data-analytics-component="footer" data-analytics-event="navigation">
      <a class="wordmark" href="/"><SaltMark size={18} />NiceSalt</a>
      <p>
        A small digital studio for expert-led brands in health, science, and
        media. The consulting practice of <a href={SITE.principal.url} rel="me">{SITE.principal.name}</a>.
      </p>
      <div>
        <a href="/case-studies/">Work</a>
        <a href="/notes/">Notes</a>
        <a href="/llms.txt">LLMs.txt</a>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </div>
      <p class="footer-fine">&copy; {new Date().getFullYear()} NiceSalt</p>
    </footer>
    <script src="/scripts/site.js" is:inline></script>
    <script src="/scripts/analytics.js" is:inline></script>
  </body>
</html>
