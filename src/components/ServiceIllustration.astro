---
/**
 * Service icons: one story per icon, told with the minimum cast.
 * one focal crystal, one support shape, one connector, one coral accent.
 * Geometry and palette per docs/illustration-style.md.
 */
type Kind = "strategy" | "content" | "conversion" | "analytics";

interface Props {
  kind: Kind;
}

const { kind } = Astro.props;
---

<figure class:list={["service-illustration", `service-illustration--${kind}`]} aria-hidden="true">
  {kind === "strategy" && (
    <!-- A page with structure; the crystal is what it earns. -->
    <svg viewBox="0 0 260 150" fill="none">
      <rect class="si-panel" x="24" y="30" width="120" height="84" rx="10" />
      <path class="si-block teal" d="M42 48h48v16H42z" />
      <path class="si-line" d="M42 80h72M42 94h50" />
      <path class="si-path" d="M144 74c16 2 26 8 32 14" />
      <g class="si-crystal si-crystal--full">
        <path class="si-crystal-facet pale" d="M198 62 L176.4 92 L198 92 Z" />
        <path class="si-crystal-facet teal" d="M198 62 L219.6 92 L198 92 Z" />
        <path class="si-crystal-facet blue" d="M198 122 L219.6 92 L198 92 Z" />
        <path class="si-crystal-facet stone" d="M198 122 L176.4 92 L198 92 Z" />
        <path class="si-crystal-seam" d="M198 62V122M176.4 92H219.6" />
        <path class="si-crystal-outline" d="M198 62 L219.6 92 L198 122 L176.4 92 Z" />
      </g>
      <path class="si-plane coral" d="M203 54l16-6v11z" />
    </svg>
  )}

  {kind === "content" && (
    <!-- One article, distributed: a source panel fanning into grains. -->
    <svg viewBox="0 0 260 150" fill="none">
      <rect class="si-panel" x="28" y="44" width="82" height="62" rx="10" />
      <path class="si-block teal" d="M42 58h24v16H42z" />
      <path class="si-line" d="M42 90h52" />
      <path class="si-path" d="M110 62c28-12 46-18 66-21M110 75h70M110 88c28 12 46 18 64 21" />
      <path class="si-plane coral" d="M150 70l11 5-11 5z" />
      <g class="si-grain">
        <path class="si-crystal-tone teal" d="M188 40 L195.2 50 L188 60 L180.8 50 Z" />
        <path class="si-crystal-seam" d="M188 40V60M180.8 50H195.2" />
      </g>
      <g class="si-grain">
        <path class="si-crystal-tone blue" d="M194 63 L202.6 75 L194 87 L185.4 75 Z" />
        <path class="si-crystal-seam" d="M194 63V87M185.4 75H202.6" />
      </g>
      <g class="si-grain">
        <path class="si-crystal-tone stone" d="M186 101 L192.5 110 L186 119 L179.5 110 Z" />
        <path class="si-crystal-seam" d="M186 101V119M179.5 110H192.5" />
      </g>
    </svg>
  )}

  {kind === "conversion" && (
    <!-- Wide attention in, one crystal out. -->
    <svg viewBox="0 0 260 150" fill="none">
      <path class="si-plane teal" d="M44 30h60v46h-20z" />
      <path class="si-plane blue" d="M104 30h60l-40 46h-20z" />
      <path class="si-plane pale" d="M96 76h16v10H96z" />
      <path class="si-plane coral" d="M100 92l4 7 4-7z" />
      <g class="si-crystal si-crystal--full">
        <path class="si-crystal-facet pale" d="M104 104 L93.9 118 L104 118 Z" />
        <path class="si-crystal-facet teal" d="M104 104 L114.1 118 L104 118 Z" />
        <path class="si-crystal-facet blue" d="M104 132 L114.1 118 L104 118 Z" />
        <path class="si-crystal-facet stone" d="M104 132 L93.9 118 L104 118 Z" />
        <path class="si-crystal-seam" d="M104 104V132M93.9 118H114.1" />
        <path class="si-crystal-outline" d="M104 104 L114.1 118 L104 132 L93.9 118 Z" />
      </g>
      <path class="si-line muted" d="M70 140h68" />
    </svg>
  )}

  {kind === "analytics" && (
    <!-- Bars measure; the trend line grows a grain. -->
    <svg viewBox="0 0 260 150" fill="none">
      <path class="si-line muted" d="M40 122h180" />
      <path class="si-block teal" d="M62 92h22v30H62z" />
      <path class="si-block blue" d="M100 74h22v48h-22z" />
      <path class="si-block stone" d="M138 54h22v68h-22z" />
      <path class="si-path" d="M73 82c31-18 66-34 100-46" />
      <g class="si-grain">
        <path class="si-crystal-tone teal" d="M184 21 L191.2 31 L184 41 L176.8 31 Z" />
        <path class="si-crystal-seam" d="M184 21V41M176.8 31H191.2" />
      </g>
      <path class="si-plane coral" d="M198 24l14-8-2 13z" />
    </svg>
  )}
</figure>
