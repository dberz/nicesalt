---
/**
 * The NiceSalt crystal: the brand mark.
 *
 * A faceted salt grain: a rhombus at the canonical 0.72 width-to-height
 * ratio (the same geometry as every grain in the hero animation), split
 * into four flat facets with paper-colored seams. See
 * docs/illustration-style.md for the full construction rules.
 */
interface Props {
  size?: number;
  class?: string;
}

const { size = 22, class: className = "" } = Astro.props;
---

<svg
  class:list={["salt-mark", className]}
  width={size}
  height={size * 1.2}
  viewBox="0 0 40 48"
  fill="none"
  aria-hidden="true"
>
  <path class="sm-facet pale" d="M20 2 L4 24 L20 24 Z" />
  <path class="sm-facet teal" d="M20 2 L36 24 L20 24 Z" />
  <path class="sm-facet blue" d="M20 46 L36 24 L20 24 Z" />
  <path class="sm-facet stone" d="M20 46 L4 24 L20 24 Z" />
  <path class="sm-seam" d="M20 2 V46 M4 24 H36" />
  <path class="sm-outline" d="M20 2 L36 24 L20 46 L4 24 Z" />
</svg>
