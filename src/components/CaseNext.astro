---
import { caseStudies } from "../data/site";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const currentIndex = caseStudies.findIndex((study) => study.slug === currentSlug);
const other = currentIndex >= 0 ? caseStudies[(currentIndex + 1) % caseStudies.length] : caseStudies[0];
---

<section class="case-next">
  <div>
    <p class="kicker">Next</p>
    <h2>Working on something similar?</h2>
    <p>A short note is enough to start. You'll hear back with a real next step.</p>
  </div>
  <div class="case-next-actions">
    <a class="button primary" href="/#contact">Start a project</a>
    {other && (
      <a class="text-link" href={`/case-studies/${other.slug}/`}>
        Read the {other.shortName} case study
      </a>
    )}
  </div>
</section>
