---
type Kind =
  | "hero"
  | "strategy"
  | "content"
  | "conversion"
  | "analytics"
  | "build"
  | "ai"
  | "divider";

interface Props {
  kind?: Kind;
  label?: string;
  class?: string;
}

const { kind = "strategy", label, class: className = "" } = Astro.props;
const decorative = !label;
---

<span
  class:list={["crystal-glyph", `crystal-glyph--${kind}`, className]}
  aria-hidden={decorative ? "true" : undefined}
  role={decorative ? undefined : "img"}
  aria-label={label}
>
  {kind === "hero" && (
    <svg viewBox="0 0 520 360" fill="none">
      <rect class="cg-panel" x="76" y="86" width="166" height="116" rx="12" />
      <rect class="cg-panel" x="296" y="72" width="132" height="168" rx="12" />
      <path class="cg-line muted" d="M132 246h88l54-76h112" />
      <path class="cg-line dotted" d="M204 118c46 12 80 34 104 66M322 250c-42 22-86 24-132 8" />
      <path class="cg-plane teal" d="M124 132h54v54h-54z" />
      <path class="cg-plane blue" d="M178 132h42v54h-42z" />
      <path class="cg-line" d="M324 118h70M324 146h44M324 174h76" />
      <path class="cg-plane pale" d="M224 238l58-72 72 54-44 82z" />
      <path class="cg-plane teal" d="M224 238l62 10 24 54-72-18z" />
      <path class="cg-plane blue" d="M282 166l4 82 68-28z" />
      <path class="cg-plane stone" d="M286 248l68-28-44 82z" />
      <path class="cg-plane coral" d="M92 248l34-20 32 24-36 30z" />
      <circle class="cg-node teal" cx="224" cy="238" r="7" />
      <circle class="cg-node blue" cx="354" cy="220" r="7" />
      <circle class="cg-node coral" cx="122" cy="252" r="6" />
    </svg>
  )}

  {kind === "strategy" && (
    <svg viewBox="0 0 120 120" fill="none">
      <path class="cg-line muted" d="M28 92h62" />
      <path class="cg-plane teal" d="M28 92l24-38 24 38z" />
      <path class="cg-plane blue" d="M52 54l18-28 20 66H76z" />
      <path class="cg-plane stone" d="M52 54l24 38H28z" />
      <path class="cg-line" d="M70 26v-14h24" />
      <path class="cg-plane coral" d="M94 12v18l-24-8v-10z" />
      <circle class="cg-node teal" cx="44" cy="72" r="4" />
      <circle class="cg-node blue" cx="70" cy="26" r="4" />
    </svg>
  )}

  {kind === "content" && (
    <svg viewBox="0 0 120 120" fill="none">
      <rect class="cg-panel" x="18" y="24" width="72" height="66" rx="8" />
      <path class="cg-plane teal" d="M30 40h24v24H30z" />
      <path class="cg-plane blue" d="M54 40h16v24H54z" />
      <path class="cg-line" d="M30 76h44M30 88h30" />
      <path class="cg-line muted" d="M82 44h20M82 56h14M82 68h22" />
      <path class="cg-line dotted" d="M72 36h24v46" />
      <path class="cg-plane coral" d="M90 76l18-10 8 16-18 10z" />
    </svg>
  )}

  {kind === "conversion" && (
    <svg viewBox="0 0 120 120" fill="none">
      <path class="cg-plane pale" d="M22 26h76L74 58v34H46V58z" />
      <path class="cg-plane teal" d="M22 26h38v32H46z" />
      <path class="cg-plane blue" d="M60 26h38L74 58H60z" />
      <path class="cg-line muted" d="M46 92h36" />
      <path class="cg-plane coral" d="M82 70l18 10-18 10z" />
      <circle class="cg-node teal" cx="46" cy="58" r="4" />
      <circle class="cg-node blue" cx="74" cy="58" r="4" />
    </svg>
  )}

  {kind === "analytics" && (
    <svg viewBox="0 0 120 120" fill="none">
      <rect class="cg-panel" x="18" y="22" width="84" height="74" rx="8" />
      <path class="cg-line muted" d="M32 78l16-18 16 10 22-30" />
      <path class="cg-plane teal" d="M32 78h16v16H32z" />
      <path class="cg-plane blue" d="M56 62h16v32H56z" />
      <path class="cg-plane stone" d="M80 44h16v50H80z" />
      <path class="cg-plane coral" d="M76 42l12-16 12 16z" />
      <circle class="cg-node teal" cx="48" cy="60" r="4" />
      <circle class="cg-node blue" cx="86" cy="40" r="4" />
    </svg>
  )}

  {kind === "build" && (
    <svg viewBox="0 0 120 120" fill="none">
      <rect class="cg-panel" x="16" y="24" width="88" height="64" rx="8" />
      <path class="cg-line" d="M30 42h28M30 58h46M30 74h26" />
      <path class="cg-plane teal" d="M72 38h20v20H72z" />
      <path class="cg-plane blue" d="M72 62h20v20H72z" />
      <path class="cg-plane coral" d="M52 92h18v18H52z" />
    </svg>
  )}

  {kind === "ai" && (
    <svg viewBox="0 0 120 120" fill="none">
      <path class="cg-line muted" d="M34 42h52M34 78h52M42 34v52M78 34v52" />
      <path class="cg-plane pale" d="M44 28h32l16 28-16 28H44L28 56z" />
      <path class="cg-plane teal" d="M28 56l16-28 16 28-16 28z" />
      <path class="cg-plane blue" d="M60 56l16-28 16 28-16 28z" />
      <path class="cg-plane coral" d="M52 48h16v16H52z" />
      <circle class="cg-node teal" cx="34" cy="42" r="4" />
      <circle class="cg-node blue" cx="86" cy="78" r="4" />
    </svg>
  )}

  {kind === "divider" && (
    <svg viewBox="0 0 760 112" fill="none">
      <path class="cg-line muted" d="M18 56h176l44-28h96l48 56h150l46-34h164" />
      <path class="cg-line dotted" d="M230 28c46 26 88 28 126 6M466 84c44-25 84-28 120-8" />
      <path class="cg-plane teal" d="M194 44l44-24 44 28-44 26z" />
      <path class="cg-plane blue" d="M344 22l44 30-44 30-44-30z" />
      <path class="cg-plane stone" d="M532 42l42-22 42 28-42 26z" />
      <path class="cg-plane coral" d="M648 48l28-16 28 20-30 18z" />
      <circle class="cg-node teal" cx="194" cy="56" r="5" />
      <circle class="cg-node blue" cx="388" cy="52" r="5" />
      <circle class="cg-node coral" cx="704" cy="52" r="5" />
    </svg>
  )}
</span>
